{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "voicy",
  "main": "worker/index.ts",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  "assets": {
    "not_found_handling": "single-page-application"
  },
  "ai": {
    "binding": "AI"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
